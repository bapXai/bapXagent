NEXT_PUBLIC_ENV_MODE="local"
NEXT_PUBLIC_DISABLE_MOBILE_ADVERTISING="true"

# Trailbase Configuration (replaces Supabase)
NEXT_PUBLIC_TRAILBASE_URL="http://localhost:4000"
NEXT_PUBLIC_TRAILBASE_ADMIN_KEY=""

# Backend API
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000/v1"

# App URLs
NEXT_PUBLIC_URL="http://localhost:3000"

# Optional: API Keys
KORTIX_ADMIN_API_KEY=""

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GA_ID_1=""
NEXT_PUBLIC_GA_ID_2=""
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=""

# Force localhost for local development
NEXT_PUBLIC_FORCE_LOCALHOST="true"
